        "@openrouter/ai-sdk-provider": "^3.0.0",
        "@sentry/bun": "^10.65.0",
        "@sentry/hono": "^10.65.0",
        "ai": "^7.0.22",
        "dotenv": "^17.4.2",
        "hono": "^4.12.29",
        "zod": "^4.4.3"
    }
}
